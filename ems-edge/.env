# =============================================================================
# ems-edge — Environment Configuration
# =============================================================================
# NOTE: This file contains NON-secret operational config only.
# Real secrets (TLS keys, cloud tokens, MQTT passwords) must NEVER live here in
# production — inject them via Docker secrets / a vault. See docs/deployment.md.
# =============================================================================

# ---- Industrial Gateway (SenseLive X5050) -----------------------------------
GATEWAY_IP=192.168.6.56
GATEWAY_PORT=4196

# ---- MQTT Broker ------------------------------------------------------------
# MQTT_HOST is resolved from INSIDE the Docker network, so it must be the
# Mosquitto service name ("mosquitto"), NOT localhost.
# Host-side tools (mosquitto_sub on your laptop) should use localhost instead.
MQTT_HOST=mosquitto
MQTT_PORT=1883

# ---- Polling ----------------------------------------------------------------
# Telegraf agent interval. Must be a Go duration string (e.g. 5s, 1m).
POLL_INTERVAL=5s

# ---- Multi-tenant / Multi-site identity -------------------------------------
# Used to build MQTT topics: ems/<PLANT_ID>/meterNN  and to tag every metric.
PLANT_ID=plant01
TENANT_ID=rucha-group

# ---- Telegraf ---------------------------------------------------------------
TELEGRAF_IMAGE=telegraf:1.30
MOSQUITTO_IMAGE=eclipse-mosquitto:2.0
