{
  "name": "ems-edge-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise IIoT Edge Ingestion Platform — Modbus TCP-Client ingestion for a multi-tenant EMS",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx watch apps/ingestion-service/src/main.ts",
    "start": "node --import tsx apps/ingestion-service/src/main.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:init": "bash scripts/migrate.sh"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.1.1",
    "@prisma/client": "^5.20.0",
    "fastify": "^5.0.0",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "tsx": "^4.19.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.11.1",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.20.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1"
  }
}
