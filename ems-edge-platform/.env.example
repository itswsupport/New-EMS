# =============================================================================
# ems-edge-platform — Environment (12-Factor: config in the environment)
# Copy to `.env` for local dev. In production inject via Docker Secrets / vault.
# NOTHING secret should be committed. This file documents keys with safe defaults.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info                       # trace|debug|info|warn|error|fatal
SERVICE_NAME=ems-edge-platform

# ---- Gateway TCP listener ---------------------------------------------------
# The SenseLive X5050 runs as a TCP CLIENT and dials US. We LISTEN.
GATEWAY_LISTEN_HOST=0.0.0.0
GATEWAY_LISTEN_PORT=4196
MAX_CONNECTIONS=512                  # simultaneous gateways this node accepts
CONNECTION_TIMEOUT_MS=30000          # idle socket timeout
CONNECTION_RATE_LIMIT_PER_MIN=120    # new-connection rate limit per source IP

# ---- Modbus polling ---------------------------------------------------------
POLL_INTERVAL_MS=5000
MODBUS_TIMEOUT_MS=3000               # per-transaction response timeout
MODBUS_MAX_RETRIES=2                 # per-register read retries before UNCERTAIN
MODBUS_BYTE_ORDER=ABCD               # ABCD|BADC|CDAB|DCBA (float32 word/byte order)

# ---- Device / register map --------------------------------------------------
DEVICE_CONFIG_PATH=./config/devices.yaml

# ---- Multi-tenant defaults (device config can override per meter) -----------
DEFAULT_TENANT_ID=rucha-engineers
DEFAULT_PLANT_ID=plant01

# ---- Database (native PostgreSQL — Prisma Accelerate NOT used) --------------
# Compose sets host=postgres. Password comes from Docker secret in prod.
DATABASE_URL=postgresql://ems:ems_dev_password@localhost:5432/ems?schema=public&connection_limit=10&pool_timeout=10
PG_VECTOR_DIMENSION=1536             # embedding dimension — NOT hardcoded in schema

# ---- Batch database writer --------------------------------------------------
DB_BATCH_SIZE=500                    # flush at N records...
DB_FLUSH_INTERVAL_MS=2000            # ...or after N ms, whichever first
DB_MAX_RETRIES=5
DB_RETRY_BACKOFF_MS=250              # base for exponential backoff
DB_DEAD_LETTER_PATH=./logs/dead-letter.ndjson

# ---- HTTP API / observability ----------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
METRICS_ENABLED=true
API_RATE_LIMIT_MAX=300               # req/window per IP
API_RATE_LIMIT_WINDOW_MS=60000

# ---- Lifecycle --------------------------------------------------------------
SHUTDOWN_TIMEOUT_MS=15000            # grace period for in-flight flush on SIGTERM
